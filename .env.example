# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Resend — emails de confirmación (https://resend.com/api-keys)
# Opcional: si no se rellena, la reserva funciona pero no se envía email.
RESEND_API_KEY=
RESEND_FROM="Línea Gentlemen <onboarding@resend.dev>"
